# Copy to supabase/functions/.env for local development (gitignored).
# For production: supabase secrets set KEY=value

# Seam (use a sandbox workspace API key for development)
SEAM_API_KEY=seam_test_...
# Optional override, e.g. a local mock or Seam sandbox endpoint
# SEAM_API_URL=https://connect.getseam.com

# Resend
RESEND_API_KEY=re_...
EMAIL_FROM=Rack <onboarding@resend.dev>

# Shared secret the pg_cron job sends in the x-cron-secret header
CRON_SECRET=change-me
