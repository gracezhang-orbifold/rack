  "compilerOptions": {
    "composite": true,
    "target": "ES2022", "lib": ["ES2023"], "module": "ESNext",
    "skipLibCheck": true, "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "outDir": "node_modules/.tmp/tsconfig.node"
  },
  "include": ["vite.config.ts"]
}
